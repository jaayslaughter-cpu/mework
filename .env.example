# PropIQ environment variables — COPY TO .env AND FILL IN REAL VALUES
# DO NOT commit .env to version control. It is listed in .gitignore.

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@host:port/railway
POSTGRES_PASSWORD=your_postgres_password_here
SPRING_DATASOURCE_PASSWORD=your_spring_db_password_here

# ── Discord ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# ── API Keys ──────────────────────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key_here
SCRAPERAPI_KEY=your_scraperapi_key_here   # fallback proxy for FanGraphs 403 blocks
TANK01_KEY=your_tank01_rapidapi_key_here
SPORTSDATA_IO_KEY=your_sportsdata_io_key_here

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# Used by the live-app frontend to call The Odds API directly.
# Prefer proxying through FastAPI backend in production so the key isn't exposed.
NEXT_PUBLIC_ODDS_API_KEY=your_odds_api_key_here

# ── CORS ──────────────────────────────────────────────────────────────────────
# Set to your deployed frontend URL(s) so the API and orchestrator allow browser requests.
# Comma-separate multiple origins: https://a.railway.app,https://b.vercel.app
FRONTEND_URL=https://your-frontend.up.railway.app

# ── Apify Proxy (Phase 100) ────────────────────────────────────────────────────
# Residential IP rotation for PrizePicks/Underdog when Railway IP is blocked.
# Get from: apify.com → Settings → API & Integrations → Personal API tokens
# Without this key the Apify fallback is silently skipped (no crash, no behavior change).
APIFY_API_KEY=your_apify_personal_api_token_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Telegram notifications (not currently used — Discord webhook preferred)
PROPIQ_TELEGRAM_BOT_TOKEN=your_bot_token_here
PROPIQ_TELEGRAM_CHAT_ID=your_chat_id_here

# Underdog Streaks entry amount ($1 default)
STREAK_ENTRY_AMOUNT=1

# ── Model accuracy & calibration ─────────────────────────────────────────────
# Enable isotonic calibration (per-prop-type, per-line-bucket probability correction).
# Set to true after first successful XGBoost retrain (needs ≥30 graded rows per bucket).
ISOTONIC_CALIBRATION_ACTIVE=true

# Calibration map path (default: calibration_map.json in working dir)
# CALIBRATION_MAP_PATH=/app/calibration_map.json

# XGBoost model path (default: /app/api/models/prop_model_v1.json)
# XGB_MODEL_PATH=/app/api/models/prop_model_v1.json

# ── Sharp reference fallback tiers ───────────────────────────────────────────
# PropOdds.com — free tier (100 calls/day). Register at prop-odds.com.
# Covers DraftKings/FanDuel/BetMGM/Caesars lines. Tier 2 after OddsAPI.
PROP_ODDS_API_KEY=your_prop_odds_key_here

# Pinnacle API — sharpest book globally. Requires account at pinnacle.com.
# Value is base64(username:password). Tier 3 after PropOdds.
# PINNACLE_API_KEY=base64encodedcredentials

# TheRundown — pitcher Ks only. Free tier key or your own from therundown.io.
# RUNDOWN_API_KEY=your_rundown_key_here

# Action Network PRO — set at Railway SERVICE level (not project).
# Required for SharpFadeAgent (fade heavy public bets) and public betting %.
# Get your Bearer JWT from Action Network PRO account.
ACTION_NETWORK_COOKIE=your_bearer_jwt_here

# ── Morning summary / alerting ────────────────────────────────────────────────
# Railway API — needed by log_watcher.py to pull dispatch logs at 9:15 AM PT.
# Get from Railway dashboard → Settings → Tokens.
RAILWAY_API_TOKEN=your_railway_token_here
RAILWAY_SERVICE_ID=your_service_id_here
RAILWAY_PROJECT_ID=your_project_id_here

# Email summary (Gmail SMTP — use App Password, not your login password)
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ── Model calibration ─────────────────────────────────────────────────────────
# Enable isotonic calibration — set to true after first successful XGBoost retrain.
# Applies per-prop-type, per-line-bucket probability correction built nightly.
ISOTONIC_CALIBRATION_ACTIVE=true
