# PropIQ environment variables — COPY TO .env AND FILL IN REAL VALUES
# DO NOT commit .env to version control. It is listed in .gitignore.

POSTGRES_PASSWORD=your_postgres_password_here
SPRING_DATASOURCE_PASSWORD=your_spring_db_password_here

# Optional: Telegram notifications (not currently used — Discord webhook preferred)
PROPIQ_TELEGRAM_BOT_TOKEN=your_bot_token_here
PROPIQ_TELEGRAM_CHAT_ID=your_chat_id_here

# Discord
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# API Keys
ODDS_API_KEY=your_odds_api_key_here
TANK01_KEY=your_tank01_rapidapi_key_here
SPORTSDATA_IO_KEY=your_sportsdata_io_key_here
