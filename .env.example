# PropIQ Agent Army — Environment Variables
# Copy to .env and fill in your values

# ── API Keys (required) ───────────────────────────────────────────────────────
SPORTSDATA_API_KEY=your_sportsdata_key_here
ODDS_API_KEY=your_odds_api_key_here
TANK01_API_KEY=your_tank01_rapidapi_key_here
APIFY_API_KEY=your_apify_key_here

# ── Infrastructure ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=propiq
POSTGRES_USER=propiq
POSTGRES_PASSWORD=change_me_before_deploying

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── App Config ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
TZ=America/Los_Angeles
